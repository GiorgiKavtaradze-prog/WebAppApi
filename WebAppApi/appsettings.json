{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "MyConnection": "Server=(localdb)\\MSSQLLocalDB;Database=MyApiDb;Trusted_Connection=true;Encrypt=false;"
  },
  "JWT": {
    "Issuer": "webapp-client",
    "Audience": "webapp-backend",
    "Key": "super_secret_key_that_is_at_least_32_characters_long_12345",
    "ExpiresInMinutes": 30
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "https://localhost:3000"
    ]
  },
  "RateLimiting": {
    "PermitLimit": 100,
    "WindowInSeconds": 60,
    "QueueLimit": 0
  },
  "AllowedHosts": "*"
}
